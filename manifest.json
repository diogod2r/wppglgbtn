{
  "manifest_version": 3,
  "name": "WhatsApp Google Search Button",
  "version": "1.0.0",
  "description": "Adiciona botão do WhatsApp ao lado do telefone no painel de conhecimento do Google.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://www.google.com/search*"],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "WhatsApp Google Search Button",
    "default_popup": "popup.html"
  }
}
